# ══════════════════════════════════════════════════════════════════════
# SHARF Devoluciones TI — Variables de Entorno
# Configurar en: Railway panel → Variables
# NUNCA subas este archivo con valores reales a GitHub
# ══════════════════════════════════════════════════════════════════════

# ── Snipe-IT ──────────────────────────────────────────────────────────
SNIPE_BASE=https://scharff.snipe-it.io/api/v1
SNIPE_TOKEN=          # Snipe-IT → avatar → Manage API Keys → Create New Token

# ── Google Service Account ────────────────────────────────────────────
# JSON completo descargado de: GCP → IAM → Cuentas de servicio → Crear clave
GOOGLE_CREDS_JSON={"type":"service_account","project_id":"..."}

# ── IDs de Drive y Sheets (ya conocidos de tu configuración GAS) ──────
SHEET_LOG_ID=14LNid3_E7deg9rHD65TA9P_h8Lmr2s0HvWoejHlYQow
DRIVE_ACTAS_ROOT=0APknu_tBOg5SUk9PVA
DRIVE_FIRMAS_ID=1EXUIcq56A23yMmvjco56gYwKr5mFRP0v
GMAIL_USER=helpdesk@holasharf.com

# ── Gmail — elige UNA opción ──────────────────────────────────────────
# Opción A (más fácil): App Password de Gmail
# myaccount.google.com → Seguridad → Contraseñas de aplicación → Crear
GMAIL_APP_PASSWORD=

# Opción B: GAS hace el envío (webhook)
GAS_WEBHOOK_URL=      # URL de tu GAS deployment
GAS_WEBHOOK_TOKEN=sharf-secret-2025

# ── JWT ───────────────────────────────────────────────────────────────
# Generar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA-ESTO-POR-UN-SECRETO-LARGO-Y-ALEATORIO-DE-64-CHARS
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_MINUTES=1440

# ── Google OAuth (para verificar id_tokens del celular) ───────────────
# GCP → APIs → Credenciales → Crear credencial → ID de cliente OAuth
# Tipo: Aplicación web
GOOGLE_CLIENT_ID=

# ── Rate limiting ─────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH=10

# ── Admin panel ───────────────────────────────────────────────────────
# Token para acceder a /api/admin/* (logs, stats, usuarios)
# Generar: python -c "import secrets; print(secrets.token_hex(16))"
ADMIN_TOKEN=CAMBIA-ESTO-TAMBIEN

# ── App ───────────────────────────────────────────────────────────────
ENV=production
LOG_LEVEL=INFO
PORT=8000
TZ=America/Lima

# ── CORS ──────────────────────────────────────────────────────────────
# URL exacta de donde viene el frontend (sin / final)
# En Railway te la dan automáticamente
FRONTEND_URL=https://sharf-ti.railway.app
